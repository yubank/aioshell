# AI Operating Shell — 로컬 설정 (YAML)
# Ollama 설치 후: 터미널에서 `ollama pull llama3.2` (또는 아래 model에 맞게 pull)

ai:
  provider: ollama
  model_key: ollama
  max_length: 512
  temperature: 0.2
  confidence_threshold: 0.5
  ollama:
    base_url: http://127.0.0.1:11434
    # 설치 후 사용 가능한 이름으로 맞추세요: ollama list
    model: llama3.2
    timeout: 180

shell:
  safe_mode: true
  command_timeout: 300

safety:
  enabled: true
  require_confirmation: true

logging:
  level: INFO
  file: logs/ai_shell.log
